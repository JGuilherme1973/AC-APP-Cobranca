# ============================================================
# AC-APP-Cobrança — ANDRADE & CINTRA Advogados
# Variáveis de Ambiente (.env.example)
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA comite o arquivo .env.local no repositório.
# ============================================================

# ── SUPABASE ─────────────────────────────────────────────────
# Obtenha em: https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Somente no backend / Edge Functions (NUNCA expor no frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave de criptografia para CPF/CNPJ (mínimo 32 caracteres aleatórios)
# Gerar: openssl rand -base64 32
SUPABASE_ENCRYPTION_KEY=

# ── STORAGE ──────────────────────────────────────────────────
# Nome do bucket Supabase Storage para documentos dos casos
VITE_STORAGE_BUCKET=documentos-cobranca

# ── RESEND (E-MAIL) ──────────────────────────────────────────
# Obtenha em: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# E-mail remetente verificado no Resend
RESEND_FROM_EMAIL=sistema@andradecintra.com.br
RESEND_FROM_NAME=ANDRADE & CINTRA Advogados

# ── WHATSAPP — EVOLUTION API (self-hosted) ───────────────────
# URL da instância Evolution API hospedada (ex: VPS própria)
EVOLUTION_API_URL=https://evolution.seudominio.com.br
EVOLUTION_API_KEY=sua-chave-api-aqui
# Nome da instância criada no painel Evolution
EVOLUTION_INSTANCE=andrade-cintra

# ── WHATSAPP — TWILIO (alternativo ao Evolution) ─────────────
# Obtenha em: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Número WhatsApp Business aprovado (formato: +5511999999999)
TWILIO_WHATSAPP_FROM=+5511996071463

# ── CONFIGURAÇÕES DO SISTEMA ─────────────────────────────────
# Ambiente: development | production
VITE_APP_ENV=development

# URL base da aplicação (sem barra final)
VITE_APP_URL=http://localhost:5173

# Horário comercial para envio automático (formato HH:MM — fuso America/Sao_Paulo)
VITE_HORARIO_COMERCIAL_INICIO=08:00
VITE_HORARIO_COMERCIAL_FIM=20:00

# ── CONFIGURAÇÕES OAB / ESCRITÓRIO ───────────────────────────
VITE_ESCRITORIO_NOME=ANDRADE & CINTRA Advogados
VITE_RESPONSAVEL_NOME=João Guilherme de Andrade Cintra
VITE_RESPONSAVEL_EMAIL=jgac@cintraadvogados.com.br
VITE_RESPONSAVEL_WHATSAPP=5511996071463
VITE_ESCRITORIO_SITE=https://www.andradecintra.com.br
