# ============================================================
# AC-APP-Cobrança — ANDRADE & CINTRA Advogados
# Variáveis de Ambiente (.env.example)
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA comite o arquivo .env.local no repositório.
# ============================================================

# ── SUPABASE ─────────────────────────────────────────────────
# Obtenha em: https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Somente no backend / Edge Functions (NUNCA expor no frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave de criptografia para CPF/CNPJ (mínimo 32 caracteres aleatórios)
# Gerar: openssl rand -base64 32
SUPABASE_ENCRYPTION_KEY=

# ── STORAGE ──────────────────────────────────────────────────
# Nome do bucket Supabase Storage para documentos dos casos
VITE_STORAGE_BUCKET=documentos-cobranca

# ── RESEND (E-MAIL) ──────────────────────────────────────────
# Obtenha em: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# E-mail remetente verificado no Resend
RESEND_FROM_EMAIL=sistema@andradecintra.com.br
RESEND_FROM_NAME=ANDRADE & CINTRA Advogados

# ── WHATSAPP — EVOLUTION API (self-hosted) ───────────────────
# URL da instância Evolution API hospedada (ex: VPS própria)
EVOLUTION_API_URL=https://evolution.seudominio.com.br
EVOLUTION_API_KEY=sua-chave-api-aqui
# Nome da instância criada no painel Evolution
EVOLUTION_INSTANCE=andrade-cintra

# ── WHATSAPP — TWILIO (alternativo ao Evolution) ─────────────
# Obtenha em: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Número WhatsApp Business aprovado (formato: +5511999999999)
TWILIO_WHATSAPP_FROM=+5511996071463

# ── CONFIGURAÇÕES DO SISTEMA ─────────────────────────────────
# Ambiente: development | production
VITE_APP_ENV=development

# URL base da aplicação (sem barra final)
VITE_APP_URL=http://localhost:5173

# Horário comercial para envio automático (formato HH:MM — fuso America/Sao_Paulo)
VITE_HORARIO_COMERCIAL_INICIO=08:00
VITE_HORARIO_COMERCIAL_FIM=20:00

# ── IUGU — GATEWAY DE PAGAMENTOS ─────────────────────────────
# Conta em: https://iugu.com → Configurações → Tokens e Chaves de API
# Sandbox: ative em Configurações → Modo Sandbox
VITE_IUGU_API_KEY=                 # API Key Live ou Sandbox (ex: abc123_...)
VITE_IUGU_ACCOUNT_ID=              # ID da conta iugu (ex: A1B2C3D4E5F6...)
VITE_IUGU_SANDBOX=true             # 'true' em dev, 'false' em produção

# Apenas backend / Supabase Edge Functions — NUNCA expor no frontend
IUGU_WEBHOOK_SECRET=               # Gerado em: iugu → Configurações → Webhooks

# ── VINDI — RECORRÊNCIA (alternativo ao Pix Automático) ──────
# Conta em: https://vindi.com.br → Minha Conta → API Keys
VINDI_API_KEY=
VINDI_PUBLIC_KEY=

# ── OPENAI — PERSONALIZAÇÃO IA (Módulo B) ────────────────────
# Conta em: https://platform.openai.com → API Keys
# ATENÇÃO: nunca use VITE_ prefix — chave somente server-side (Edge Function ia-regua)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURA=0.3

# ── PORTAL SELF-SERVICE (Módulo B) ───────────────────────────
# URL base — usada para compor links enviados ao devedor via régua
VITE_PORTAL_BASE_URL=https://app.andradecintra.com.br
# Validade do token do portal em dias (padrão: 7)
PORTAL_TOKEN_EXPIRACAO_DIAS=7

# ── MÓDULO C — PROTESTO E NEGATIVAÇÃO ────────────────────────
# ATENÇÃO: Estas chaves NÃO devem ter prefixo VITE_ — ficam somente
# no Supabase Secrets (Settings → Edge Functions → Secrets).
# As Edge Functions proxy-serasa, proxy-eprotesto acessam via Deno.env.get().

# e-Protesto / CRI Digital — somente no Supabase Secrets:
#   EPROTESTO_API_KEY=...
#   EPROTESTO_API_URL=https://api.eprotesto.com.br/v1

# Serasa Experian — somente no Supabase Secrets:
#   SERASA_API_KEY=...
#   SERASA_API_URL=https://api.serasaexperian.com.br/v1

# SPC Brasil — somente no Supabase Secrets:
#   SPC_API_KEY=...
#   SPC_API_URL=https://api.spcbrasil.org.br/v1

# E-mail do administrador para relatório diário do job de negativação
ADMIN_EMAIL=jgac@cintraadvogados.com.br

# ── MÓDULO D — LGPD + SEGURANÇA ──────────────────────────────

# SERPRO — validação de CPF e CNPJ em tempo real
# ATENÇÃO: somente no Supabase Secrets (Edge Function proxy-serpro):
#   SERPRO_CPF_API_KEY=...
#   SERPRO_CNPJ_API_KEY=...
#   SERPRO_API_URL=https://gateway.apiserpro.serpro.gov.br

# Criptografia AES-256-GCM — chave de 32 bytes (64 hex chars)
# Gerar: openssl rand -hex 32
# ATENÇÃO: NUNCA versionar — guardar no Supabase Secrets como ENCRYPTION_KEY_AES256
VITE_ENCRYPTION_KEY=                # 64 chars hex — somente em dev local; produção usa Supabase Secrets

# ClickSign — assinatura digital
# https://developers.clicksign.com
CLICKSIGN_API_KEY=
CLICKSIGN_API_URL=https://sandbox.clicksign.com  # trocar para app.clicksign.com em produção

# ── CONFIGURAÇÕES OAB / ESCRITÓRIO ───────────────────────────
VITE_ESCRITORIO_NOME=ANDRADE & CINTRA Advogados
VITE_RESPONSAVEL_NOME=João Guilherme de Andrade Cintra
VITE_RESPONSAVEL_EMAIL=jgac@cintraadvogados.com.br
VITE_RESPONSAVEL_WHATSAPP=5511996071463
VITE_ESCRITORIO_SITE=https://www.andradecintra.com.br
